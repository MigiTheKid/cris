# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (segredos nunca vão pro Git; exemplo sim)
.env*
!.env.example

# Claude Code (settings do projeto entram; locais/pessoais não)
.claude/settings.local.json

# Referência de design (protótipos do Claude Design — não versionar)
/_design
/design_handoff_cris

# Playwright
/playwright-report
/test-results

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
