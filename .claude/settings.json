{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx shadcn:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(supabase:*)",
      "PowerShell(pnpm dev:*)",
      "PowerShell(pnpm build:*)",
      "PowerShell(pnpm test:*)",
      "PowerShell(pnpm typecheck:*)",
      "PowerShell(pnpm lint:*)",
      "PowerShell(pnpm format:*)",
      "PowerShell(pnpm exec:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(supabase:*)"
    ],
    "deny": ["Bash(git push --force:*)", "Bash(rm -rf:*)", "Read(./.env.local)", "Read(./.env)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"try { $up = (Test-Connection -TargetName localhost -TcpPort 3210 -Quiet -TimeoutSeconds 1); if (-not $up) { Start-Process -WindowStyle Hidden pnpm -ArgumentList 'dev' -WorkingDirectory 'C:\\dev\\cris' }; Write-Output 'CRIS dev server: http://localhost:3210' } catch { Write-Output 'CRIS: inicie o dev com pnpm dev' }\""
          }
        ]
      }
    ]
  }
}
